# ローカル開発用の環境変数テンプレート。コピーして.env.localを作成する:
#   cp .env.local.example .env.local
# 本番(EC2)はこれらをSSMから読むため.envは不要。

# --- DB（アプリ実行用。ローカルはcompose.yamlのPostgresに接続） ---
# アプリは常にこの DB_* から接続URLを組み立てる（非所有者 monolog_app ＝ RLS が効く）。
DB_HOST=localhost
DB_PORT=5433
DB_NAME=monolog
DB_USER=monolog_app      # RLSを効かせるため非所有者ロールで接続
DB_PASSWORD=localapppw   # prisma/migrations の init が作る初期パスワード

# --- Prisma CLI 用（migrate/generate/db pull が読む。アプリは上の DB_* を使う） ---
# 所有者(monolog_admin)で接続。CLI 実行時にインライン指定するか、別途 .env に置く:
#   DATABASE_URL="postgresql://monolog_admin:localdev@localhost:5433/monolog" npx prisma migrate deploy
# DATABASE_URL=postgresql://monolog_admin:localdev@localhost:5433/monolog

# --- AWS（Cognito/S3は実物を参照。認証情報は~/.awsを自動使用） ---
AWS_REGION=ap-northeast-1

# 値はterraform apply後に取得してそれぞれ貼る:
#   aws ssm get-parameter --region ap-northeast-1 --name /mono-log/cognito/user_pool_id --query Parameter.Value --output text
#   aws ssm get-parameter --region ap-northeast-1 --name /mono-log/cognito/client_id    --query Parameter.Value --output text
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# 画像用S3バケット名（mono-log-item-images-<アカウントID>）
S3_IMAGE_BUCKET=
